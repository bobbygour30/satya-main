DirectoryIndex index.html

Options -Indexes -MultiViews
RewriteEngine On

# Bot Detection - Redirect social media crawlers to OG endpoint
RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slack|discordbot|pinterest|facebookbot|facebot|Googlebot) [NC]
RewriteCond %{REQUEST_URI} ^/case/(.+)$
RewriteRule ^case/(.+)$ https://satya-admin-backend.vercel.app/api/og/%1 [L,R=302]

# Handle static files and HTML files
# If request is for a file that exists (css, js, images), serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If request is for a directory, serve index.html from that directory
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)/$ $1/index.html [L]

# Check if .html file exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*?)/?$ $1.html [L]

# For blog posts and dynamic routes, fallback to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# Kill Hostinger / GoDaddy cache
<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
</IfModule>

<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>